# ==========================================
# 数据库配置（四选一）
# ==========================================

# 选项 1: Cloudflare D1（默认，Cloudflare Pages/Workers 部署）
# 无需配置，通过 wrangler.toml 绑定即可

# 选项 2: 本地 SQLite（本地开发）
# 无需配置，自动使用 ./data/typos.db
# 确保已安装：npm install better-sqlite3

# 选项 3: PostgreSQL / Neon（Vercel/Netlify/通用部署）
# DATABASE_URL=postgres://user:password@host:5432/database
# 或 Neon：
# DATABASE_URL=neon://user:password@host/database

# 选项 4: Turso（边缘 SQLite）
# DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token_here

# ==========================================
# 管理员配置（必需）
# ==========================================

# Admin dashboard password. No default is provided.
ADMIN_PASSWORD=

# Session signing secret. Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

