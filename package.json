{
  "name": "typos",
  "version": "1.0.0",
  "description": "Typos — A minimal HUD-styled personal publishing system built with Next.js 16, Tailwind CSS 4, and Cloudflare D1",
  "private": false,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0 <11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler d1 migrations apply DB --remote && opennextjs-cloudflare deploy",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote",
    "db:migrations:apply:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "node scripts/migrate.js",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@shikijs/rehype": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "heic2any": "^0.0.4",
    "katex": "^0.17.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.31.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "ogl": "^1.0.11",
    "postprocessing": "^6.38.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.5.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "optionalDependencies": {
    "@libsql/client": "^0.14.0",
    "@neondatabase/serverless": "^0.10.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260206.0",
    "@tailwindcss/postcss": "^4.0.7",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.0.7",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
